}
/* ==========================================================
   HERO SECTION
   ========================================================== */

.hero{

min-height:85vh;

display:flex;

align-items:center;

justify-content:center;

text-align:center;

padding:100px 20px;

position:relative;

overflow:hidden;

background:
radial-gradient(circle at top,
rgba(0,208,132,.12),
transparent 45%),
linear-gradient(180deg,
#07120f,
#050b09);

}

.hero::before{

content:"";

position:absolute;

top:-180px;

left:50%;

transform:translateX(-50%);

width:550px;

height:550px;

background:rgba(0,208,132,.10);

filter:blur(100px);

border-radius:50%;

}

.hero-content{

position:relative;

z-index:2;

max-width:850px;

}

.hero-badge{

display:inline-block;

padding:8px 18px;

margin-bottom:25px;

border-radius:999px;

background:rgba(0,208,132,.10);

border:1px solid rgba(0,208,132,.30);

color:var(--science-green);

font-size:.85rem;

font-weight:700;

}

.hero h1{

margin-bottom:24px;

}

.hero h1 span{

color:var(--science-green);

}

.hero p{

max-width:720px;

margin:0 auto 2rem;

font-size:1.15rem;

}

.hero-content{

animation:heroFade 1s ease;

}

@keyframes heroFade{

from{

opacity:0;

transform:translateY(30px);

}

to{

opacity:1;

transform:translateY(0);

}

}
/* ==========================================================
   KNOWLEDGE LIBRARY
========================================================== */

.section-padding{

padding:90px 0;

}

.library-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(300px,1fr));

gap:30px;

align-items:stretch;

}

/* ==========================================================
   PREMIUM CARDS
========================================================== */

.card{

background:linear-gradient(
145deg,
#112019,
#0b1612
);

border:1px solid var(--border);

border-radius:var(--radius);

padding:30px;

transition:var(--transition);

position:relative;

overflow:hidden;

height:100%;

}

.card::before{

content:"";

position:absolute;

left:0;

top:0;

width:100%;

height:3px;

background:var(--science-green);

transform:scaleX(0);

transition:var(--transition);

}

.card:hover{

transform:translateY(-8px);

box-shadow:var(--shadow);

border-color:rgba(0,208,132,.35);

}

.card:hover::before{

transform:scaleX(1);

}

.card-tag{

display:inline-block;

padding:6px 14px;

margin-bottom:18px;

border-radius:999px;

background:rgba(0,208,132,.10);

color:var(--science-green);

font-size:.82rem;

font-weight:700;

}

.card h3{

margin-bottom:16px;

}

.card p{

margin-bottom:20px;

}

.card-link-wrapper{

display:block;

height:100%;

color:inherit;

}
/* ==========================================================
   PREMIUM ARTICLE PAGES
========================================================== */

.article-page{

background:
radial-gradient(circle at top,
rgba(0,208,132,.08),
transparent 35%),
var(--bg);

}

.article-container{

width:min(900px,92%);

margin:60px auto;

padding:50px;

background:linear-gradient(
145deg,
rgba(18,32,26,.96),
rgba(10,18,15,.96)
);

border:1px solid var(--border);

border-radius:24px;

box-shadow:var(--shadow);

}

.article-container h1{

margin-bottom:25px;

}

.article-container h2{

margin-top:45px;

margin-bottom:18px;

color:var(--science-green);

}

.article-container h3{

margin-top:30px;

margin-bottom:12px;

}

.article-container p{

margin-bottom:22px;

}

.article-container ul,
.article-container ol{

margin:20px 0 25px 24px;

}

.article-container li{

margin-bottom:12px;

color:var(--text-muted);

}

.article-container strong{

color:var(--science-green);

}

blockquote,
.quote{

margin:35px 0;

padding:25px;

border-left:4px solid var(--science-green);

background:rgba(0,208,132,.08);

border-radius:12px;

font-style:italic;

color:#fff;

}

.article-back{

width:min(900px,92%);

margin:30px auto 0;

}

.article-back a{

display:inline-flex;

align-items:center;

gap:8px;

font-weight:700;

color:var(--science-green);

transition:var(--transition);

}

.article-back a:hover{

transform:translateX(-5px);

}
/* ==========================================================
   ARTICLE COMPONENTS
========================================================== */

/* Editorial Information */

.article-info{

max-width:900px;

margin:2rem auto;

padding:0 1.5rem;

}

.info-box{

background:var(--surface);

border:1px solid var(--border);

border-radius:var(--radius);

padding:24px;

}

.info-box p{

margin-bottom:.8rem;

}

/* Hero Image */

.article-hero-image{

display:block;

width:100%;

max-width:900px;

height:auto;

margin:2rem auto;

border-radius:20px;

box-shadow:var(--shadow);

}

/* Science Visual */

.science-visual{

max-width:900px;

margin:3rem auto;

padding:0 1.5rem;

}

/* Related Articles */

.related-articles,

.read-next{

margin:3rem auto;

padding:2rem;

background:var(--surface);

border:1px solid var(--border);

border-radius:var(--radius);

}

.related-articles h2,

.read-next h2{

margin-bottom:1rem;

color:var(--science-green);

}

.related-articles ul{

list-style:disc;

padding-left:1.5rem;

}

.related-articles li{

margin-bottom:12px;

}

.related-articles a,

.read-next a{

color:var(--science-green);

font-weight:600;

transition:var(--transition);

}

.related-articles a:hover,

.read-next a:hover{

opacity:.85;

}

/* Previous / Next Navigation */

.article-navigation{

display:flex;

justify-content:space-between;

gap:20px;

margin:4rem auto;

max-width:900px;

}

.article-navigation a{

flex:1;

padding:18px;

border:1px solid var(--border);

border-radius:var(--radius);

background:var(--surface);

transition:var(--transition);

font-weight:700;

}

.article-navigation a:hover{

transform:translateY(-4px);

border-color:var(--science-green);

box-shadow:var(--shadow);

}
/* ==========================================================
   FOOTER
========================================================== */

.footer{

margin-top:80px;

padding:60px 20px;

background:#050b09;

border-top:1px solid var(--border);

text-align:center;

}

.footer p{

margin:0;

color:var(--text-muted);

font-size:.95rem;

}

.footer span{

color:var(--science-green);

font-weight:700;

}

/* ==========================================================
   UTILITIES
========================================================== */

.text-center{

text-align:center;

}

.glow{

box-shadow:
0 0 30px rgba(0,208,132,.25);

}

.fade-in{

animation:fadeIn .8s ease forwards;

}

.hidden{

display:none;

}

/* ==========================================================
   ANIMATIONS
========================================================== */

@keyframes fadeIn{

from{

opacity:0;

transform:translateY(20px);

}

to{

opacity:1;

transform:translateY(0);

}

}
/* ==========================================================
   ARTICLE CONTENT SYSTEM
   Designed for scalable scientific publishing
========================================================== */

.article-content{

max-width:900px;

margin:0 auto;

padding:40px 20px;

line-height:1.8;

color:var(--text-primary);

}


/* Article headings */

.article-content h1{

font-size:clamp(2rem,5vw,3.5rem);

line-height:1.15;

margin-bottom:25px;

font-weight:800;

letter-spacing:-0.03em;

}


.article-content h2{

font-size:clamp(1.5rem,3vw,2.2rem);

margin-top:60px;

margin-bottom:20px;

color:var(--science-green);

font-weight:700;

}


.article-content h3{

font-size:1.3rem;

margin-top:40px;

margin-bottom:15px;

font-weight:700;

}


/* Paragraph system */

.article-content p{

font-size:1.05rem;

margin-bottom:25px;

color:var(--text-secondary);

}


/* Scientific emphasis */

.article-content strong{

color:var(--text-primary);

font-weight:700;

}


/* Links inside articles */

.article-content a{

color:var(--science-green);

text-decoration:none;

font-weight:600;

transition:.3s ease;

}


.article-content a:hover{

text-decoration:underline;

}


/* Article lists */

.article-content ul,
.article-content ol{

margin:25px 0;

padding-left:35px;

color:var(--text-secondary);

}


.article-content li{

margin-bottom:12px;

}


/* Scientific quote / key insight blocks */

.article-quote{

margin:40px 0;

padding:30px;

border-left:4px solid var(--science-green);

background:rgba(0,208,132,.05);

border-radius:12px;

font-size:1.1rem;

}


/* Article images */

.article-content img{

width:100%;

height:auto;

display:block;

margin:40px auto;

border-radius:18px;

}


/* Article captions */

.image-caption{

text-align:center;

font-size:.9rem;

color:var(--text-muted);

margin-top:-25px;

margin-bottom:40px;

}


/* Reading experience */

.article-content blockquote{

margin:40px 0;

padding:25px;

border-radius:12px;

background:var(--bg-secondary);

font-style:italic;

color:var(--text-secondary);

}
/* ==========================================================
   ARTICLE METADATA SYSTEM
   Designed for scalable knowledge publishing
========================================================== */

.article-meta{

display:flex;

flex-wrap:wrap;

gap:15px;

align-items:center;

margin:25px 0 40px;

padding-bottom:25px;

border-bottom:1px solid var(--border);

color:var(--text-muted);

font-size:.9rem;

}


/* Metadata items */

.meta-item{

display:flex;

align-items:center;

gap:8px;

}


/* Category labels */

.article-category{

display:inline-block;

padding:6px 14px;

border-radius:50px;

background:rgba(0,208,132,.12);

color:var(--science-green);

font-size:.85rem;

font-weight:700;

}


/* Reading time */

.reading-time{

color:var(--text-secondary);

}


/* Article author information */

.article-author{

display:flex;

align-items:center;

gap:12px;

margin:30px 0;

}


.author-avatar{

width:45px;

height:45px;

border-radius:50%;

background:var(--bg-secondary);

display:flex;

align-items:center;

justify-content:center;

font-weight:700;

color:var(--science-green);

}


.author-details{

display:flex;

flex-direction:column;

}


.author-name{

font-weight:700;

color:var(--text-primary);

}


.author-role{

font-size:.85rem;

color:var(--text-muted);

}


/* Article status badges */

.article-badge{

padding:5px 12px;

border-radius:20px;

font-size:.8rem;

font-weight:700;

background:var(--bg-secondary);

color:var(--science-green);

}


/* Publication date */

.article-date{

font-size:.9rem;

color:var(--text-muted);

}


/* Mobile adjustment */

@media(max-width:768px){

.article-meta{

flex-direction:column;

align-items:flex-start;

}

}
/* ==========================================================
   ARTICLE NAVIGATION SYSTEM
   Designed for large-scale knowledge discovery
========================================================== */

.article-navigation{

display:flex;

justify-content:space-between;

gap:25px;

margin:60px 0;

padding-top:40px;

border-top:1px solid var(--border);

}


/* Navigation cards */

.nav-card{

flex:1;

padding:25px;

background:var(--bg-secondary);

border-radius:16px;

text-decoration:none;

transition:.3s ease;

border:1px solid transparent;

}


/* Hover effect */

.nav-card:hover{

border-color:var(--science-green);

transform:translateY(-5px);

}


/* Navigation labels */

.nav-label{

display:block;

font-size:.8rem;

text-transform:uppercase;

letter-spacing:.1em;

color:var(--text-muted);

margin-bottom:10px;

}


/* Navigation titles */

.nav-title{

font-size:1.05rem;

font-weight:700;

color:var(--text-primary);

}


/* Previous article */

.nav-prev{

text-align:left;

}


/* Next article */

.nav-next{

text-align:right;

}


/* Related article section */

.related-articles{

margin:80px 0;

padding:40px;

background:var(--bg-secondary);

border-radius:20px;

}


.related-title{

font-size:1.8rem;

margin-bottom:30px;

color:var(--text-primary);

}


/* Mobile navigation */

@media(max-width:768px){

.article-navigation{

flex-direction:column;

}


.nav-next,
.nav-prev{

text-align:left;

}

}
/* ==========================================================
   ARTICLE RESEARCH ELEMENTS SYSTEM
   Designed for scientific knowledge presentation
========================================================== */

.research-box{

margin:40px 0;

padding:35px;

background:var(--bg-secondary);

border-radius:18px;

border:1px solid var(--border);

}


/* Research box heading */

.research-box h3{

margin-top:0;

margin-bottom:20px;

color:var(--science-green);

font-size:1.4rem;

}


/* Key findings */

.key-findings{

display:flex;

flex-direction:column;

gap:15px;

}


/* Finding item */

.finding-item{

padding:20px;

border-radius:12px;

background:#050b09;

border-left:3px solid var(--science-green);

}


.finding-item strong{

display:block;

margin-bottom:8px;

color:var(--text-primary);

}


/* Scientific highlight */

.highlight-box{

padding:25px;

margin:35px 0;

background:rgba(0,208,132,.06);

border-radius:14px;

border:1px solid rgba(0,208,132,.2);

}


.highlight-box p{

margin:0;

}


/* Data/statistics display */

.data-point{

display:flex;

justify-content:space-between;

align-items:center;

gap:20px;

padding:18px 0;

border-bottom:1px solid var(--border);

}


.data-label{

color:var(--text-secondary);

}


.data-value{

font-size:1.2rem;

font-weight:800;

color:var(--science-green);

}


/* Mobile adjustment */

@media(max-width:768px){

.data-point{

flex-direction:column;

align-items:flex-start;

}

}
/* ==========================================================
   ARTICLE MEDIA SYSTEM
   Designed for scientific visual publishing
========================================================== */

.article-media{

margin:50px 0;

}


/* Media container */

.media-container{

position:relative;

overflow:hidden;

border-radius:20px;

background:var(--bg-secondary);

}


/* Media images */

.media-container img{

width:100%;

height:auto;

display:block;

transition:transform .5s ease;

}


/* Image interaction */

.media-container:hover img{

transform:scale(1.03);

}


/* Media caption */

.media-caption{

padding:15px 20px;

font-size:.9rem;

color:var(--text-muted);

text-align:center;

}


/* Scientific diagrams */

.science-diagram{

margin:50px auto;

max-width:100%;

padding:25px;

background:var(--bg-secondary);

border-radius:18px;

border:1px solid var(--border);

}


/* Diagram title */

.diagram-title{

font-size:1.1rem;

font-weight:700;

margin-bottom:15px;

color:var(--text-primary);

}


/* Video / animation placeholder */

.media-video{

width:100%;

aspect-ratio:16/9;

background:#050b09;

border-radius:18px;

display:flex;

align-items:center;

justify-content:center;

color:var(--science-green);

font-weight:700;

}


/* Mobile media adjustment */

@media(max-width:768px){

.article-media{

margin:35px 0;

}

.science-diagram{

padding:15px;

}

}
/* ==========================================================
   ARTICLE ENGAGEMENT SYSTEM
   Designed for long-term knowledge discovery
========================================================== */

.article-engagement{

margin:70px 0;

}


/* Topic tags */

.topic-tags{

display:flex;

flex-wrap:wrap;

gap:12px;

margin:30px 0;

}


.topic-tag{

padding:8px 16px;

border-radius:50px;

background:var(--bg-secondary);

border:1px solid var(--border);

color:var(--text-secondary);

font-size:.9rem;

text-decoration:none;

transition:.3s ease;

}


.topic-tag:hover{

color:var(--science-green);

border-color:var(--science-green);

}


/* Learning pathway */

.learning-path{

padding:35px;

background:var(--bg-secondary);

border-radius:20px;

margin:50px 0;

}


.path-title{

font-size:1.5rem;

font-weight:700;

margin-bottom:25px;

color:var(--text-primary);

}


/* Path items */

.path-item{

display:flex;

align-items:center;

gap:15px;

padding:15px 0;

border-bottom:1px solid var(--border);

}


.path-number{

width:35px;

height:35px;

border-radius:50%;

display:flex;

align-items:center;

justify-content:center;

background:rgba(0,208,132,.12);

color:var(--science-green);

font-weight:700;

}


.path-text{

color:var(--text-secondary);

}


/* Article feedback area */

.article-feedback{

margin-top:50px;

padding:30px;

background:var(--bg-secondary);

border-radius:18px;

text-align:center;

}


.feedback-title{

font-size:1.2rem;

font-weight:700;

margin-bottom:15px;

}


/* Mobile adjustment */

@media(max-width:768px){

.path-item{

align-items:flex-start;

}

}
/* ==========================================================
   ARTICLE AUTHORITY SYSTEM
   Designed for scientific credibility and transparency
========================================================== */

.article-authority{

margin:80px 0;

padding:40px;

background:var(--bg-secondary);

border-radius:20px;

}


/* Authority heading */

.authority-title{

font-size:1.8rem;

font-weight:800;

margin-bottom:30px;

color:var(--text-primary);

}


/* Sources section */

.sources-list{

display:flex;

flex-direction:column;

gap:15px;

}


/* Source item */

.source-item{

padding:18px;

border-left:3px solid var(--science-green);

background:#050b09;

border-radius:10px;

color:var(--text-secondary);

}


/* Source links */

.source-item a{

color:var(--science-green);

text-decoration:none;

font-weight:600;

}


.source-item a:hover{

text-decoration:underline;

}


/* Research methodology */

.methodology-box{

margin:40px 0;

padding:30px;

border:1px solid var(--border);

border-radius:16px;

}


/* Methodology title */

.methodology-title{

font-size:1.2rem;

font-weight:700;

margin-bottom:15px;

color:var(--science-green);

}


/* Editorial note */

.editorial-note{

padding:25px;

margin:40px 0;

background:rgba(0,208,132,.05);

border-radius:14px;

color:var(--text-secondary);

}


/* Mobile adjustment */

@media(max-width:768px){

.article-authority{

padding:25px;

}

}
/* ==========================================================
   ARTICLE ACCESSIBILITY SYSTEM
   Designed for professional long-term readability
========================================================== */

.article-reading-tools{

display:flex;

justify-content:flex-end;

align-items:center;

gap:15px;

margin-bottom:30px;

}


/* Reading buttons */

.reading-btn{

width:40px;

height:40px;

border-radius:50%;

border:1px solid var(--border);

background:var(--bg-secondary);

color:var(--text-primary);

display:flex;

align-items:center;

