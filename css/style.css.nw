}

}
/* ==========================================================
   RESEARCH COLLABORATION NETWORK SYSTEM
   Designed for scientific partnerships and discovery
========================================================== */

.collaboration-section{

margin:90px 0;

}


/* Collaboration header */

.collaboration-header{

margin-bottom:45px;

}


.collaboration-title{

font-size:2.3rem;

font-weight:800;

color:var(--text-primary);

margin-bottom:15px;

}


.collaboration-description{

max-width:750px;

color:var(--text-secondary);

line-height:1.8;

}


/* Collaboration grid */

.collaboration-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(270px,1fr));

gap:30px;

margin-top:40px;

}


/* Collaboration card */

.collaboration-card{

padding:35px;

background:var(--bg-secondary);

border-radius:22px;

border:1px solid var(--border);

transition:.3s ease;

}


.collaboration-card:hover{

transform:translateY(-6px);

border-color:var(--science-green);

}


/* Collaboration type */

.collaboration-type{

display:inline-block;

padding:7px 15px;

border-radius:50px;

background:rgba(0,208,132,.12);

color:var(--science-green);

font-size:.8rem;

font-weight:700;

margin-bottom:18px;

}


/* Collaboration title */

.collaboration-card h3{

color:var(--text-primary);

margin-bottom:15px;

}


/* Collaboration text */

.collaboration-card p{

color:var(--text-secondary);

line-height:1.7;

}


/* Mobile collaboration */

@media(max-width:768px){

.collaboration-grid{

grid-template-columns:1fr;

}

}
